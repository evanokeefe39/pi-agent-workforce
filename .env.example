# Provider API keys — add the ones you use
DEEPSEEK_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
NVIDIA_NIM_API_KEY=
MINIMAX_API_KEY=

# Web search/fetch (Exa API — used by web-search extension)
EXA_API_KEY=

# Web scraping (Apify API — used by web-scrape extension tier 4)
APIFY_API_TOKEN=

# Postgres (shared instance for Paperclip + artifact store)
POSTGRES_PASSWORD=paperclip-eval
ARTIFACT_DB_PASSWORD=artifact-eval

# MinIO (S3-compatible object store)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Bridge defaults (override per-agent via agent .env if needed)
BRIDGE_PORT=8080
BRIDGE_TIMEOUT_MS=120000
LOG_LEVEL=info

# Logging extension
LOG_BUFFER_SIZE=1000
LOG_JSONL_ENABLED=true

# Discord integration (via paperclip-plugin-discord)
# Set these to enable Discord notifications and escalations during setup.sh
# If unset, plugin is installed but unconfigured (no Discord features)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
DISCORD_APPROVALS_CHANNEL_ID=
DISCORD_ERRORS_CHANNEL_ID=
DISCORD_ESCALATION_CHANNEL_ID=

# Discord plugin ID — set after setup.sh installs the plugin
# When set, escalate tool routes through Discord instead of Paperclip UI
PAPERCLIP_DISCORD_PLUGIN_ID=
