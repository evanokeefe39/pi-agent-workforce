# LLM Provider API keys — add the ones you use
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
NVIDIA_NIM_API_KEY=

# Web search (Exa API — used by web-search extension)
EXA_API_KEY=

# Web scraping (Apify API — used by web-scrape extension)
APIFY_API_TOKEN=

# Postgres
POSTGRES_PASSWORD=pi-agent-workforce
ARTIFACT_DB_PASSWORD=artifact-eval

# MinIO (S3-compatible object store)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# OpenObserve (traces, logs, metrics)
ZO_ROOT_USER_EMAIL=admin@example.com
ZO_ROOT_USER_PASSWORD=pi-agent-workforce
ZO_OTLP_AUTH=

# Agent defaults (override per-agent in docker-compose.yml)
BRIDGE_TIMEOUT_MS=120000
LOG_LEVEL=info
