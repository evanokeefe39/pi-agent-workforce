{
  "name": "Data",
  "role": "engineer",
  "title": "Data Analyst",
  "icon": "database",
  "reportsTo": "CEO",
  "capabilities": "Code-first data analysis via DuckDB SQL and Python. Receives raw data artifacts from researcher, computes statistical summaries, metrics, trend analysis, and structured datasets.",
  "adapterType": "http",
  "adapterConfig": {
    "url": "http://data:8080/invoke",
    "timeoutSec": 300
  },
  "runtimeConfig": {
    "heartbeat": { "enabled": false, "intervalSec": 300, "wakeOnDemand": true, "cooldownSec": 30, "maxConcurrentRuns": 3 },
    "validation": {
      "maxTurns": 60,
      "requiredTools": ["write_artifact", "record_query_result"],
      "requiredArtifactType": "dataset"
    },
    "toolPolicy": {
      "write": "block",
      "edit": "block",
      "record_query_result": "allow",
      "record_metric": "allow",
      "record_chart": "allow",
      "record_dataset_ref": "allow",
      "write_artifact": "allow",
      "read": "allow",
      "bash": "allow"
    }
  }
}
