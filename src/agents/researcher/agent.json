{
  "name": "Researcher",
  "role": "researcher",
  "title": "Research Analyst",
  "icon": "search",
  "reportsTo": "CEO",
  "capabilities": "Information gathering, structured research, source analysis",
  "adapterType": "http",
  "adapterConfig": {
    "url": "http://researcher:8080/invoke",
    "timeoutSec": 300
  },
  "runtimeConfig": {
    "heartbeat": { "enabled": false, "intervalSec": 300, "wakeOnDemand": true, "cooldownSec": 30, "maxConcurrentRuns": 3 },
    "validation": {
      "maxTurns": 60,
      "requiredTools": ["record_finding", "write_artifact"],
      "requiredArtifactType": "dataset"
    },
    "toolPolicy": {
      "write": "block",
      "edit": "block",
      "record_finding": "allow",
      "write_artifact": "allow",
      "read": "allow",
      "bash": "allow",
      "web_search": "allow",
      "deep_research": "allow",
      "scrape_apify": "allow"
    }
  }
}
